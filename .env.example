# Vercel Storage Postgres connection string.
# On Vercel this is injected automatically after you connect a Postgres store.
POSTGRES_URL=postgresql://user:password@host/database?sslmode=require

# Local fallback. You can use DATABASE_URL instead of POSTGRES_URL while developing.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Authentication Secret (generate a random string).
# AUTHSECRET / JWT_SECRET are also accepted on Vercel for compatibility.
AUTH_SECRET=your-random-secret-key-change-me

